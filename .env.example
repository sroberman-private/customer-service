# =============================================================================
# .env.example — copy to .env and fill in real values for local overrides.
# NEVER commit .env to version control.
# For production, inject these via Docker secrets or your orchestrator's
# secret management (ECS task definitions, Kubernetes Secrets, etc.).
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── PostgreSQL (prod only) ────────────────────────────────────────────────────
# DB_URL=jdbc:postgresql://postgres:5432/customerdb
# DB_USERNAME=customer_user
# DB_PASSWORD=change_me_in_production

# ── JVM / container tuning ────────────────────────────────────────────────────
# JAVA_OPTS=-XX:MaxRAMPercentage=75.0
